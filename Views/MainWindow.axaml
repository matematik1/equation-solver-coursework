<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
        xmlns:oxy="http://oxyplot.org/avalonia"
        x:Class="EquationSolver.Views.MainWindow"
        Title="Розв'язання нелінійних рівнянь" Width="1050" Height="785"
        MinWidth="800" MinHeight="600"
        Icon="/ico/app.ico">

    <Window.Styles>
        <Style Selector="TextBlock.Header">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="TextBlock.Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
        <Style Selector="TextBlock.Hint">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style Selector="TextBlock.Error">
            <Setter Property="Foreground" Value="#FF5555"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,15,0,0"/>
        </Style>
        <Style Selector="TextBlock.Warning">
            <Setter Property="Foreground" Value="#FFAA00"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>
        <Style Selector="Button.Math">
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,5,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="350, *" RowDefinitions="*, Auto">
        <!-- Left Panel: Inputs -->
        <Border Grid.Column="0" Grid.Row="0" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="*, Auto">
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Border Padding="20">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Налаштування" Classes="Header" Margin="0,0,0,15"/>

                        <TextBlock Text="Функція f(x):" Classes="Label"/>
                        <TextBox Name="FunctionInput" Text="{Binding Equation.Expression}" Watermark="Напр: x^2 - 4"/>
                        
                        <WrapPanel Margin="0,5,0,0">
                            <Button Content="^" Classes="Math" Tag="^" Click="MathButton_Click" ToolTip.Tip="Степінь"/>
                            <Button Content="√" Classes="Math" Tag="sqrt()" Click="MathButton_Click" ToolTip.Tip="Квадратний корінь"/>
                            <Button Content="sin" Classes="Math" Tag="sin()" Click="MathButton_Click"/>
                            <Button Content="cos" Classes="Math" Tag="cos()" Click="MathButton_Click"/>
                            <Button Content="tan" Classes="Math" Tag="tan()" Click="MathButton_Click"/>
                            <Button Content="ln" Classes="Math" Tag="ln()" Click="MathButton_Click" ToolTip.Tip="Натуральний логарифм"/>
                            <Button Content="log" Classes="Math" Tag="log10()" Click="MathButton_Click" ToolTip.Tip="Десятковий логарифм"/>
                            <Button Content="abs" Classes="Math" Tag="abs()" Click="MathButton_Click" ToolTip.Tip="Модуль"/>
                            <Button Content="exp" Classes="Math" Tag="exp()" Click="MathButton_Click"/>
                            <Button Content="π" Classes="Math" Tag="pi" Click="MathButton_Click"/>
                            <Button Content="e" Classes="Math" Tag="e" Click="MathButton_Click"/>
                        </WrapPanel>
                        
                        <TextBlock Text="Використовуйте панель для швидкої вставки функцій" Classes="Hint" FontStyle="Italic"/>
                        <TextBlock Text="Підтримуються: ^, sqrt(), sin(), cos(), tan(), ln(), log(), abs(), exp(), pi, e" Classes="Hint"/>

                        <TextBlock Text="Інтервал [a, b]:" Classes="Label"/>
                        <Grid ColumnDefinitions="*,15,*">
                            <TextBox Grid.Column="0" Text="{Binding Equation.A}" Watermark="a" />
                            <TextBlock Grid.Column="1" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                            <TextBox Grid.Column="2" Text="{Binding Equation.B}" Watermark="b" />
                        </Grid>
                        <TextBlock Text="Макс. різниця: 10 000 | До 15 знаків" Classes="Hint"/>

                        <StackPanel IsVisible="{Binding IsNewtonMethod}">
                            <TextBlock Text="Початкове наближення:" Classes="Label"/>
                            <TextBox Text="{Binding Equation.InitialGuess}" Watermark="x0"/>
                            <TextBlock Text="Допустимо: ±1 000 000 | До 15 знаків" Classes="Hint"/>
                        </StackPanel>

                        <TextBlock Text="Точність (Epsilon):" Classes="Label"/>
                        <TextBox Text="{Binding Equation.Epsilon}" Watermark="1e-5"/>
                        <TextBlock Text="Від 1e-15 до 1" Classes="Hint"/>

                        <TextBlock Text="Макс. ітерацій:" Classes="Label"/>
                        <TextBox Text="{Binding Equation.MaxIterations}" Watermark="100"/>
                        <TextBlock Text="Від 1 до 1 000 000" Classes="Hint"/>

                        <TextBlock Text="Метод розв'язання:" Classes="Label"/>
                        <ComboBox ItemsSource="{Binding AvailableMethods}" SelectedItem="{Binding SelectedMethod}" HorizontalAlignment="Stretch" />

                        <Button Content="Розв'язати" Command="{Binding SolveCommand}" IsEnabled="{Binding !IsBusy}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
                                Background="#007acc" Foreground="White" FontWeight="Bold" Margin="0,20,0,0"/>

                        <Button Content="Скасувати" Command="{Binding CancelCommand}" IsEnabled="{Binding IsBusy}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,5,0,0"/>

                        <Button Content="Зберегти результати" Command="{Binding SaveCommand}" IsEnabled="{Binding !IsBusy}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,5,0,0"/>

                        <TextBlock Text="{Binding ErrorMessage}" IsVisible="{Binding IsErrorVisible}" Classes="Error"/>
                        <TextBlock Text="{Binding WarningMessage}" IsVisible="{Binding IsWarningVisible}" Classes="Warning"/>
                    </StackPanel>
                </Border>
                </ScrollViewer>

                <!-- Calculation Status Overlay/Bar -->
                <Border Grid.Row="1" IsVisible="{Binding IsBusy}" Background="#007acc" Padding="10">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="100" Height="4" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="Обчислення..." Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Right Panel: Graph and Results -->
        <Grid Grid.Column="1" Grid.Row="0" RowDefinitions="3*, 2*">
            <!-- Top: Graph -->
            <Border Grid.Row="0" Margin="15" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="8" ClipToBounds="True" BoxShadow="0 2 5 0 #20000000">
                <oxy:PlotView Model="{Binding PlotModel}" MinHeight="250"/>
            </Border>

            <!-- Bottom: Results -->
            <Grid Grid.Row="1" Margin="15,0,15,15" RowDefinitions="Auto, *">
                <StackPanel Grid.Row="0" Margin="0,0,0,10" IsVisible="{Binding IsRootVisible}">
                    <TextBlock Text="Знайдений корінь:" FontWeight="Bold" FontSize="16" Foreground="#007acc"/>
                    <Border Background="Black" CornerRadius="4" Padding="10" Margin="0,5,0,0">
                        <TextBlock Text="{Binding RootCoordinates}" FontSize="15" FontWeight="Medium" Foreground="White"/>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" CornerRadius="4">
                    <dg:DataGrid ItemsSource="{Binding Iterations}" AutoGenerateColumns="False" IsReadOnly="True"
                                 CanUserSortColumns="True" GridLinesVisibility="All" 
                                 HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <dg:DataGrid.Columns>
                            <dg:DataGridTextColumn Header="№" Binding="{Binding IterationNumber}" Width="50" />
                            <dg:DataGridTextColumn Header="Xn" Binding="{Binding Xn}" Width="*" />
                            <dg:DataGridTextColumn Header="f(Xn)" Binding="{Binding FXn}" Width="*" />
                            <dg:DataGridTextColumn Header="Похибка" Binding="{Binding Error}" Width="*" />
                        </dg:DataGrid.Columns>
                    </dg:DataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>