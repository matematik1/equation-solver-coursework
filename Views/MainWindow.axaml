<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
        xmlns:oxy="http://oxyplot.org/avalonia"
        x:Class="EquationSolver.Views.MainWindow"
        Title="Розв'язання нелінійних рівнянь" Width="1000" Height="700">

    <Grid ColumnDefinitions="320, *" RowDefinitions="5*, 4*">
        <!-- Left Panel: Inputs -->
        <Border Grid.Column="0" Grid.RowSpan="2" Padding="15" Background="Black" BorderBrush="#545454" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <TextBlock Text="Налаштування" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>

                    <TextBlock Text="Функція f(x):" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Equation.Expression}" />

                    <TextBlock Text="Інтервал [a, b]:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <Grid ColumnDefinitions="*,10,*">
                        <TextBox Grid.Column="0" Text="{Binding Equation.A}" />
                        <TextBlock Grid.Column="1" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox Grid.Column="2" Text="{Binding Equation.B}" />
                    </Grid>

                    <StackPanel IsVisible="{Binding IsNewtonMethod}">
                        <TextBlock Text="Початкове наближення:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        <TextBox Text="{Binding Equation.InitialGuess}" Margin="0,10,0,0"/>
                    </StackPanel>

                    <TextBlock Text="Точність (Epsilon):" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding Equation.Epsilon}" />

                    <TextBlock Text="Макс. ітерацій:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding Equation.MaxIterations}" />

                    <TextBlock Text="Метод розв'язання:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <ComboBox ItemsSource="{Binding AvailableMethods}" SelectedItem="{Binding SelectedMethod}" HorizontalAlignment="Stretch" />

                    <Button Content="Розв'язати" Command="{Binding SolveCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#007acc" Foreground="White" FontWeight="Bold" Margin="0,15,0,0"/>
                    <Button Content="Скасувати" Command="{Binding CancelCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" IsEnabled="{Binding IsBusy}"/>
                    <Button Content="Зберегти результати" Command="{Binding SaveCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" IsVisible="{Binding IsErrorVisible}" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding WarningMessage}" Foreground="Orange" TextWrapping="Wrap" IsVisible="{Binding IsWarningVisible}" FontWeight="SemiBold" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Panel Top: Graph -->
        <Border Grid.Column="1" Grid.Row="0" Margin="10" BorderBrush="#d0d0d0" BorderThickness="1" CornerRadius="5">
            <oxy:PlotView Model="{Binding PlotModel}" />
        </Border>

        <!-- Right Panel Bottom: Results -->
        <Grid Grid.Column="1" Grid.Row="1" Margin="10,0,10,10" RowDefinitions="Auto, Auto, *">
            <ProgressBar Grid.Row="0" IsIndeterminate="True" IsVisible="{Binding IsBusy}" Margin="0,0,0,10"/>
            
            <StackPanel Grid.Row="1" Margin="0,0,0,10" IsVisible="{Binding IsRootVisible}">
                <TextBlock Text="Знайдений корінь:" FontWeight="Bold" FontSize="14" Foreground="#007acc"/>
                <TextBlock Text="{Binding RootCoordinates}" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
            
            <dg:DataGrid Grid.Row="2" ItemsSource="{Binding Iterations}" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="100">
                <dg:DataGrid.Columns>
                    <dg:DataGridTextColumn Header="№" Binding="{Binding IterationNumber}" />
                    <dg:DataGridTextColumn Header="Xn" Binding="{Binding Xn}" />
                    <dg:DataGridTextColumn Header="f(Xn)" Binding="{Binding FXn}" />
                    <dg:DataGridTextColumn Header="Похибка" Binding="{Binding Error}" />
                </dg:DataGrid.Columns>
            </dg:DataGrid>
        </Grid>
    </Grid>
</Window>